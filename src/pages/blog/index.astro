---
import "../../styles/global.css";
import { getCollection } from "astro:content";
import dayjs from "dayjs";
import { appConfig } from "@/shared/app.config";
import Layout from "../../layouts/main.astro";

const posts = (await getCollection("blog")).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<Layout
	content={{ title: `blog | ${appConfig.title}`, description: "ブログ一覧" }}
>
	<section class="space-y-8">
		<h1 class="text-xl font-bold">blog</h1>
		<ul class="list-outside list-disc space-y-3">
			{posts.map((post) => (
				<li class="ms-6">
					<article>
						<a
							href={`/blog/${post.id}`}
							class="text-foreground/50 hover:text-foreground transition-colors hover:underline hover:bg-primary/10 decoration-primary underline-offset-4"
						>
							{post.data.title}
							<span class="font-mono">
								{dayjs(post.data.pubDate).format("（YYYY-MM-DD）")}
							</span>
						</a>
					</article>
				</li>
			))}
		</ul>
	</section>
</Layout>
