---
import "../styles/global.css";
import { appConfig } from "@/shared/app.config";
import Footer from "../components/footer.astro";
import Header from "../components/header.astro";

interface Content {
	title: string;
	description: string;
	type?: "website" | "article";
	publishedTime?: string;
	modifiedTime?: string;
}

const { content } = Astro.props as { content: Content };
const url = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL(appConfig.ogImage, Astro.site);
const ogType = content.type ?? "website";
---

<!-- mode toggle -->
<script is:inline>
const getThemePreference = () => {
	if (typeof localStorage !== "undefined" && localStorage.getItem("theme")) {
		return localStorage.getItem("theme");
	}

	return window.matchMedia("(prefers-color-scheme: dark)").matches
		? "dark"
		: "light";
};
const isDark = getThemePreference() === "dark";
document.documentElement.classList[isDark ? "add" : "remove"]("dark");

if (typeof localStorage !== "undefined") {
	const observer = new MutationObserver(() => {
		const isDark = document.documentElement.classList.contains("dark");
		localStorage.setItem("theme", isDark ? "dark" : "light");
	});
	observer.observe(document.documentElement, {
		attributes: true,
		attributeFilter: ["class"],
	});
}
</script>

<html lang="ja" class="scroll-smooth">
	<head>
		<meta charset="utf-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		<meta name="description" content={content.description}>
		<link rel="canonical" href={url}>
		<meta property="og:type" content={ogType}>
		<meta property="og:site_name" content={appConfig.title}>
		<meta property="og:locale" content="ja_JP">
		<meta property="og:url" content={url}>
		<meta property="og:title" content={content.title}>
		<meta property="og:description" content={content.description}>
		<meta property="og:image" content={ogImage}>
		<meta property="og:image:width" content="1200">
		<meta property="og:image:height" content="630">
		<meta property="og:image:alt" content={appConfig.title}>
		{ogType === "article" && content.publishedTime && (
			<meta property="article:published_time" content={content.publishedTime} />
		)}
		{ogType === "article" && content.modifiedTime && (
			<meta property="article:modified_time" content={content.modifiedTime} />
		)}
		<meta name="twitter:card" content="summary">
		<meta name="twitter:site" content={appConfig.xHandle}>
		<meta name="twitter:creator" content={appConfig.xHandle}>
		<meta name="twitter:title" content={content.title}>
		<meta name="twitter:description" content={content.description}>
		<meta name="twitter:image" content={ogImage}>
		<link rel="icon" href="/favicon.ico">
		<title>{content.title}</title>
	</head>
	<body
		class="container mx-auto min-h-dvh max-w-4xl overflow-y-scroll px-6 lg:px-8 pt-40 font-sans"
	>
		<Header />
		<main><slot /></main>
		<Footer />
	</body>
</html>
